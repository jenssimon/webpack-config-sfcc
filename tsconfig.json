{
  "compilerOptions": {
    "declaration": true,
    "target": "es2021",
    "outDir": "dist",
    "rootDir": "src/",
    "moduleResolution": "node",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Advanced Options */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "ignoreDeprecations": "6.0"
  }
}
